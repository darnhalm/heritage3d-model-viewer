    <mxCell id="e11" value="ownerOrganizationId" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16a34a;strokeWidth=2;endArrow=block;endFill=1;fontColor=#16a34a;fontStyle=1;" edge="1" parent="1" source="organization" target="object">
