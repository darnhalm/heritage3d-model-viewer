    <mxCell id="e5" value="участники группы" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ca8a04;strokeWidth=2;endArrow=block;endFill=1;fontColor=#ca8a04;fontStyle=1;" edge="1" parent="1" source="workgroup" target="membership">
      <mxGeometry relative="1" as="geometry" />
