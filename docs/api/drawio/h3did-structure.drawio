    <mxCell id="e6" value="роль -&gt; права" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ef4444;strokeWidth=2;endArrow=block;endFill=1;fontColor=#ef4444;fontStyle=1;" edge="1" parent="1" source="membership" target="permissions">
