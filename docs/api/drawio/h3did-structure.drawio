      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e15" value="h3druObjectId" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=2;endArrow=block;endFill=1;fontColor=#2563eb;fontStyle=1;" edge="1" parent="1" source="h3did" target="object">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e16" value="имеет цифровые двойники" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0284c7;strokeWidth=2;endArrow=block;endFill=1;fontColor=#0284c7;fontStyle=1;" edge="1" parent="1" source="object" target="twin">
      <mxGeometry relative="1" as="geometry" />
