    <mxCell id="e10" value="объекты подколлекции" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7c3aed;strokeWidth=2;endArrow=block;endFill=1;fontColor=#7c3aed;fontStyle=1;" edge="1" parent="1" source="collection-child" target="object">
